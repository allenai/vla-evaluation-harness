# VLABench evaluation environment (MuJoCo-based)

ARG BASE_IMAGE=ghcr.io/allenai/vla-evaluation-harness/base:latest
FROM ${BASE_IMAGE}

ENV VLABENCH_ROOT=/app/VLABench/VLABench

# Create conda env with Python 3.10
RUN conda create -n vlabench python=3.10 pip -y && conda clean -afy

SHELL ["conda", "run", "-n", "vlabench", "/bin/bash", "-c"]

# Install MuJoCo, dm_control, and numpy first
RUN uv pip install --no-cache-dir \
        mujoco==3.2.2 \
        dm_control==1.0.22 \
        numpy==1.25.0

# Install remaining VLABench dependencies
RUN uv pip install --no-cache-dir \
        gym==0.26.2 \
        gymnasium==0.29.1 \
        opencv-python==4.11.0.86 \
        scipy==1.14.0 \
        h5py==3.11.0 \
        mediapy==1.2.0 \
        imageio==2.37.3 \
        gdown==6.1.0 \
        colorlog==6.10.1 \
        colorama==0.4.6 \
        ipdb==0.13.13 \
        pillow==12.2.0 \
        open3d==0.18.0 \
        scikit-learn==1.7.2 \
        openai==2.44.0

# Clone and install rrt-algorithms (required by VLABench skill_lib)
ARG RRT_ALGORITHMS_REF=e51d95ee489a225220d6ae2a764c4111f6ba7d85
RUN mkdir -p /app/rrt-algorithms && \
    cd /app/rrt-algorithms && \
    git init -q && \
    git remote add origin https://github.com/motion-planning/rrt-algorithms.git && \
    git fetch -q --depth 1 origin "${RRT_ALGORITHMS_REF}" && \
    git checkout -q FETCH_HEAD && \
    uv pip install --no-cache-dir -e . && \
    rm -rf /app/rrt-algorithms/.git

# Clone and install VLABench
ARG VLABENCH_REF=cf588fe60c0c7282174fe979f5913170cfe69017
RUN mkdir -p /app/VLABench && \
    cd /app/VLABench && \
    git init -q && \
    git remote add origin https://github.com/OpenMOSS/VLABench.git && \
    git fetch -q --depth 1 origin "${VLABENCH_REF}" && \
    git checkout -q FETCH_HEAD && \
    uv pip install --no-cache-dir -e . && \
    rm -rf /app/VLABench/.git

# Download assets (obj + scene from Google Drive)
RUN cd /app/VLABench && \
    python scripts/download_assets.py || \
    echo "WARNING: Asset download failed — may need manual download"

# Install harness
WORKDIR /workspace
COPY pyproject.toml README.md ./
COPY src/ src/
ARG HARNESS_VERSION=0.0.0
ENV SETUPTOOLS_SCM_PRETEND_VERSION=${HARNESS_VERSION}
RUN uv pip install --no-cache-dir -e .
COPY configs/ configs/

ENTRYPOINT ["conda", "run", "--no-capture-output", "-n", "vlabench", "vla-eval"]
